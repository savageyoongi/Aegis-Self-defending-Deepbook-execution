# Sui / DeepBook testnet settings
SUI_ENV=testnet
SUI_PRIVATE_KEY=suiprivkey1_replace_with_a_throwaway_testnet_key

# Created by `npm run deepbook:setup`
BALANCE_MANAGER_KEY=MANAGER_1
BALANCE_MANAGER_ADDRESS=0x_replace_after_setup
BALANCE_MANAGER_TRADE_CAP=

# Default DeepBook V3 pool and intent
POOL_KEY=SUI_DBUSDC
PAY_WITH_DEEP=true
INTENT_SIDE=buy
INTENT_QUANTITY=750
INTENT_MAX_SLIPPAGE_BPS=80
INTENT_URGENCY=normal

# Keep true until the wallet and BalanceManager are funded.
DEEPBOOK_DRY_RUN=false
AEGIS_SCENARIO=toxic
